import java.util.*;

class Solution {
    public List<Integer> targetIndices(int[] nums, int target) {
        
        Arrays.sort(nums); // Step 1: sort array
        
        List<Integer> result = new ArrayList<>();
        
        // Step 2: find indices of target
        for (int i = 0; i < nums.length; i++) {
            if (nums[i] == target) {
                result.add(i);
            }
        }
        
        return result;
    }
}
