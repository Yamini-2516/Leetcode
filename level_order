
class Solution {
    public List<List<Integer>> levelOrder(TreeNode root) {
        List<List<Integer>> res=new ArrayList<>();
        if(root==null)
        return res;
        Queue<TreeNode> q=new LinkedList<>();
        q.offer(root);
        while(!q.isEmpty()){
            int sz=q.size();
            List<Integer> minres=new ArrayList<>();
            while(sz>0){
                TreeNode temp=q.peek();
                q.poll();
                minres.add(temp.val);
                if(temp.left!= null)
                q.offer(temp.left);
                if(temp.right!= null)
                q.offer(temp.right);
                sz--;
            }
            res.add(minres);
        }
        return res;
    }
}
