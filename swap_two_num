class Solution {
    public ListNode swapPairs(ListNode head) {
        ListNode dummy=new ListNode();
        ListNode c1;
        ListNode c2;
        ListNode temp=dummy;
        temp.next=head;
        if(head==null || head.next==null){
            return head;
        }
        while(temp.next!=null && temp.next.next!=null){
        c1=temp.next;
        c2=temp.next.next;
        c1.next=c2.next;
        c2.next=c1;
        temp.next=c2;
        temp=c1;
    }
    return dummy.next;
}
}
